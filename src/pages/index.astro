---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE, SITE_URL, SIDEBAR_ADS, ADSENSE_ID, ADSENSE_ENABLED } from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const siteId = SITE_URL.replace('https://', '').replace('.pages.dev', '');
const thumbMap = new Map<string, string>();
for (const p of posts) {
	const m = p.body?.match(/!\[.*?\]\((.*?)\)/);
	thumbMap.set(p.id, m ? m[1] : `/images/blog/${siteId}-${p.id}-01.jpg`);
}
const getThumb = (slug: string) => thumbMap.get(slug) || `/images/blog/${siteId}-${slug}-01.jpg`;
const now = new Date();
const sevenDaysAgo = new Date(now.getTime() - 7 * 24 * 60 * 60 * 1000);
const isNew = (date: Date) => date >= sevenDaysAgo;
const categories = [...new Set(posts.map(p => p.data.category))];
const featuredPost = posts[0];
const restPosts = posts.slice(1);
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<!-- Structured Data: WebSite -->
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "WebSite",
			"name": SITE_TITLE,
			"description": SITE_DESCRIPTION,
			"url": Astro.site ? Astro.site.href : ""
		})}></script>
	</head>
	<body>
		<Header />
		<div class="page-wrapper">
			<main>
				<!-- Hero (animated) -->
				<section class="hero">
					<div class="hero-bg"></div>
					<div class="hero-content">
						<h1>3ヶ月後、<br><span class="gradient-text">世界が広がる</span></h1>
						<p class="hero-sub">オンライン英会話比較・英語学習アプリ・TOEIC対策。初心者が効率よく英語を身につける方法を解説。</p>
						<div class="hero-stats">
							<div class="stat-item">
								<span class="stat-num">{posts.length}+</span>
								<span class="stat-label">記事</span>
							</div>
							<div class="stat-divider"></div>
							<div class="stat-item">
								<span class="stat-num">{categories.length}</span>
								<span class="stat-label">カテゴリ</span>
							</div>
							<div class="stat-divider"></div>
							<div class="stat-item">
								<span class="stat-num">毎週</span>
								<span class="stat-label">更新中</span>
							</div>
						</div>
						<a href="/blog" class="hero-btn">記事を読む →</a>
					</div>
				</section>

				<!-- Inline Banner Ad -->
				<section class="inline-banner">
					<h3>英語力で人生の選択肢を広げよう</h3>
					<p>オンライン英会話・TOEIC対策・ビジネス英語を徹底比較</p>
					<a href={SIDEBAR_ADS[0].url} class="cta-btn" rel="nofollow">詳しく見る →</a>
					<img border="0" width="1" height="1" src={SIDEBAR_ADS[0].pixel} alt="">
				</section>

				<!-- Featured Spotlight -->
				{featuredPost && (
					<section class="spotlight">
						<h2 class="section-title">PICK UP</h2>
						<a href={`/blog/${featuredPost.id}/`} class="spotlight-card">
							<div class="spotlight-img">
								<img src={getThumb(featuredPost.id)} alt={featuredPost.data.title} loading="lazy" onerror="this.style.display='none'" />
								<div class="spotlight-img-fallback"></div>
								{isNew(featuredPost.data.pubDate) && <span class="badge-new">NEW</span>}
							</div>
							<div class="spotlight-body">
								<span class="tag">{featuredPost.data.category}</span>
								<h3>{featuredPost.data.title}</h3>
								<p>{featuredPost.data.description}</p>
								<span class="spotlight-date"><FormattedDate date={featuredPost.data.pubDate} /></span>
							</div>
						</a>
					</section>
				)}

				<!-- Ranking -->
				<section class="ranking-section">
					<h2 class="section-title">人気記事ランキング</h2>
					<div class="ranking-list">
						{posts.slice(0, 3).map((post, i) => (
							<a href={`/blog/${post.id}/`} class={`ranking-item rank-${i + 1}`}>
								<span class="ranking-number">{i + 1}</span>
								<div class="ranking-thumb">
									<img src={getThumb(post.id)} alt={post.data.title} loading="lazy" onerror="this.style.display='none'" />
									<div class="ranking-thumb-fallback"></div>
								</div>
								<div class="ranking-content">
									<div class="ranking-meta">
										<span class="tag">{post.data.category}</span>
										{isNew(post.data.pubDate) && <span class="badge-new">NEW</span>}
									</div>
									<h3>{post.data.title}</h3>
									<p>{post.data.description}</p>
								</div>
							</a>
						))}
					</div>
				</section>

				{ADSENSE_ENABLED && ADSENSE_ID && (
					<div class="section-adsense">
						<div class="ad-label">広告</div>
						<ins class="adsbygoogle"
							style="display:block"
							data-ad-client={ADSENSE_ID}
							data-ad-slot="auto"
							data-ad-format="fluid"
							data-ad-layout-key="-6t+ed+2i-1n-4w"></ins>
					</div>
				)}

				<!-- Mid CTA -->
				<section class="cta-box">
					<h3>英語学習を始めたい方へ</h3>
					<p>オンライン英会話・アプリ・教材を比較して最適な学習法を見つけよう。</p>
					<a href={SIDEBAR_ADS[0].url} class="cta-btn" rel="nofollow">おすすめサービスを見る →</a>
					<img border="0" width="1" height="1" src={SIDEBAR_ADS[0].pixel} alt="">
				</section>

				<!-- Latest Posts (with thumbnails) -->
				<section class="posts-section">
					<h2 class="section-title">最新記事</h2>
					<div class="posts-grid">
						{restPosts.map((post) => (
							<a href={`/blog/${post.id}/`} class="post-card">
								<div class="post-card-thumb">
									<img src={getThumb(post.id)} alt={post.data.title} loading="lazy" onerror="this.style.display='none'" />
									<div class="post-card-thumb-fallback"></div>
								</div>
								<div class="post-card-body">
									<div class="post-meta">
										<span class="tag">{post.data.category}</span>
										<FormattedDate date={post.data.pubDate} />
										{isNew(post.data.pubDate) && <span class="badge-new">NEW</span>}
									</div>
									<h3>{post.data.title}</h3>
									<p>{post.data.description}</p>
								</div>
							</a>
						))}
					</div>
				</section>

				{ADSENSE_ENABLED && ADSENSE_ID && (
					<div class="section-adsense">
						<div class="ad-label">広告</div>
						<ins class="adsbygoogle"
							style="display:block"
							data-ad-client={ADSENSE_ID}
							data-ad-slot="auto"
							data-ad-format="auto"
							data-full-width-responsive="true"></ins>
					</div>
				)}

				<!-- Bottom CTA -->
				<section class="cta-box">
					<h3>英語学習を始めよう</h3>
					<p>英語は世界を広げる。まずは無料体験で一歩踏み出しましょう。</p>
					<a href={SIDEBAR_ADS[0].url} class="cta-btn" rel="nofollow">無料で始める →</a>
					<img border="0" width="1" height="1" src={SIDEBAR_ADS[0].pixel} alt="">
				</section>
			</main>

			<!-- Sidebar (unchanged - read from existing file) -->
			<!-- Sidebar (unchanged - read from existing file) -->
			<!-- Sidebar (unchanged) -->
			<aside class="sidebar">
				<div class="sidebar-scroll">
					{SIDEBAR_ADS[0] && (
						<div class="sidebar-ad">
							<h4>{SIDEBAR_ADS[0].heading}</h4>
							<p>{SIDEBAR_ADS[0].desc}</p>
							<a href={SIDEBAR_ADS[0].url} class="cta-btn" rel="nofollow">{SIDEBAR_ADS[0].cta}</a>
							<img border="0" width="1" height="1" src={SIDEBAR_ADS[0].pixel} alt="">
						</div>
					)}

					{ADSENSE_ENABLED && ADSENSE_ID && (
						<div class="sidebar-adsense">
							<div class="ad-label">広告</div>
							<ins class="adsbygoogle"
								style="display:block"
								data-ad-client={ADSENSE_ID}
								data-ad-slot="auto"
								data-ad-format="rectangle"
								data-full-width-responsive="false"></ins>
						</div>
					)}

					{SIDEBAR_ADS[1] && (
						<div class="sidebar-ad">
							<h4>{SIDEBAR_ADS[1].heading}</h4>
							<p>{SIDEBAR_ADS[1].desc}</p>
							<a href={SIDEBAR_ADS[1].url} class="cta-btn" rel="nofollow">{SIDEBAR_ADS[1].cta}</a>
							<img border="0" width="1" height="1" src={SIDEBAR_ADS[1].pixel} alt="">
						</div>
					)}

					<div class="sidebar-popular">
						<h4>人気の記事</h4>
						{posts.slice(0, 5).map((post) => (
							<a href={`/blog/${post.id}/`}>{post.data.title}</a>
						))}
					</div>

					{ADSENSE_ENABLED && ADSENSE_ID && (
						<div class="sidebar-adsense">
							<div class="ad-label">広告</div>
							<ins class="adsbygoogle"
								style="display:block"
								data-ad-client={ADSENSE_ID}
								data-ad-slot="auto"
								data-ad-format="rectangle"
								data-full-width-responsive="false"></ins>
						</div>
					)}

					{SIDEBAR_ADS[0] && (
						<div class="sidebar-cta-gradient">
							<h4>おすすめ</h4>
							<p>{SIDEBAR_ADS[0].desc}</p>
							<a href={SIDEBAR_ADS[0].url} class="cta-btn" rel="nofollow">{SIDEBAR_ADS[0].cta}</a>
							<img border="0" width="1" height="1" src={SIDEBAR_ADS[0].pixel} alt="">
						</div>
					)}

					{SIDEBAR_ADS[1] && (
						<div class="sidebar-banner">
							<div class="banner-label">PR</div>
							<h4>{SIDEBAR_ADS[1].heading}</h4>
							<a href={SIDEBAR_ADS[1].url} class="cta-btn" rel="nofollow">{SIDEBAR_ADS[1].cta}</a>
							<img border="0" width="1" height="1" src={SIDEBAR_ADS[1].pixel} alt="">
						</div>
					)}

					<div class="sidebar-popular">
						<h4>おすすめ記事</h4>
						{posts.slice(5, 10).map((post) => (
							<a href={`/blog/${post.id}/`}>{post.data.title}</a>
						))}
					</div>

					{SIDEBAR_ADS[0] && (
						<div class="sidebar-ad">
							<h4>まだ迷ってる？</h4>
							<p>{SIDEBAR_ADS[0].desc}</p>
							<a href={SIDEBAR_ADS[0].url} class="cta-btn" rel="nofollow">{SIDEBAR_ADS[0].cta}</a>
							<img border="0" width="1" height="1" src={SIDEBAR_ADS[0].pixel} alt="">
						</div>
					)}

					{SIDEBAR_ADS[1] && (
						<div class="sidebar-cta-gradient">
							<h4>今すぐチェック</h4>
							<p>{SIDEBAR_ADS[1].desc}</p>
							<a href={SIDEBAR_ADS[1].url} class="cta-btn" rel="nofollow">{SIDEBAR_ADS[1].cta}</a>
							<img border="0" width="1" height="1" src={SIDEBAR_ADS[1].pixel} alt="">
						</div>
					)}

					<div class="sidebar-popular">
						<h4>新着記事</h4>
						{posts.slice(10, 15).map((post) => (
							<a href={`/blog/${post.id}/`}>{post.data.title}</a>
						))}
					</div>

					{SIDEBAR_ADS[0] && (
						<div class="sidebar-banner">
							<div class="banner-label">注目</div>
							<h4>{SIDEBAR_ADS[0].heading}</h4>
							<p>{SIDEBAR_ADS[0].desc}</p>
							<a href={SIDEBAR_ADS[0].url} class="cta-btn" rel="nofollow">{SIDEBAR_ADS[0].cta}</a>
							<img border="0" width="1" height="1" src={SIDEBAR_ADS[0].pixel} alt="">
						</div>
					)}

					{SIDEBAR_ADS[1] && (
						<div class="sidebar-cta-gradient">
							<h4>読者に人気</h4>
							<p>{SIDEBAR_ADS[1].desc}</p>
							<a href={SIDEBAR_ADS[1].url} class="cta-btn" rel="nofollow">{SIDEBAR_ADS[1].cta}</a>
							<img border="0" width="1" height="1" src={SIDEBAR_ADS[1].pixel} alt="">
						</div>
					)}

					<div class="sidebar-popular">
						<h4>よく読まれている記事</h4>
						{posts.slice(0, 3).map((post) => (
							<a href={`/blog/${post.id}/`}>{post.data.title}</a>
						))}
					</div>

					{SIDEBAR_ADS[0] && (
						<div class="sidebar-ad">
							<h4>あなたへのおすすめ</h4>
							<p>{SIDEBAR_ADS[0].desc}</p>
							<a href={SIDEBAR_ADS[0].url} class="cta-btn" rel="nofollow">{SIDEBAR_ADS[0].cta}</a>
							<img border="0" width="1" height="1" src={SIDEBAR_ADS[0].pixel} alt="">
						</div>
					)}

					{SIDEBAR_ADS[1] && (
						<div class="sidebar-banner">
							<div class="banner-label">PR</div>
							<h4>{SIDEBAR_ADS[1].heading}</h4>
							<a href={SIDEBAR_ADS[1].url} class="cta-btn" rel="nofollow">{SIDEBAR_ADS[1].cta}</a>
							<img border="0" width="1" height="1" src={SIDEBAR_ADS[1].pixel} alt="">
						</div>
					)}

					<div class="sidebar-popular">
						<h4>カテゴリ人気記事</h4>
						{posts.slice(3, 8).map((post) => (
							<a href={`/blog/${post.id}/`}>{post.data.title}</a>
						))}
					</div>

					{SIDEBAR_ADS[0] && (
						<div class="sidebar-cta-gradient">
							<h4>見逃してない？</h4>
							<p>{SIDEBAR_ADS[0].desc}</p>
							<a href={SIDEBAR_ADS[0].url} class="cta-btn" rel="nofollow">{SIDEBAR_ADS[0].cta}</a>
							<img border="0" width="1" height="1" src={SIDEBAR_ADS[0].pixel} alt="">
						</div>
					)}

				</div>
			</aside>
		</div>
		<div class="footer-ad-section">
			{ADSENSE_ENABLED && ADSENSE_ID && (
				<div class="footer-adsense">
					<div class="ad-label">広告</div>
					<ins class="adsbygoogle"
						style="display:block"
						data-ad-client={ADSENSE_ID}
						data-ad-slot="auto"
						data-ad-format="auto"
						data-full-width-responsive="true"></ins>
				</div>
			)}
		</div>
		<Footer />

	<script is:inline>
		document.addEventListener('DOMContentLoaded', function() {
			document.querySelectorAll('.adsbygoogle').forEach(function() {
				try { (adsbygoogle = window.adsbygoogle || []).push({}); } catch(e) {}
			});
		});
	</script>
	<!-- Cloudflare Web Analytics --><script defer src='https://static.cloudflareinsights.com/beacon.min.js' data-cf-beacon='{"token": "f0fb4bab21184064b2defd0c70d04ec3"}'></script><!-- End Cloudflare Web Analytics -->
	</body>
</html>

<style>
	/* Hero */
	.hero {
		position: relative;
		background: linear-gradient(135deg, var(--black) 0%, #2b2320 100%);
		border-radius: var(--radius);
		padding: 56px 48px 64px;
		text-align: center;
		overflow: hidden;
		box-shadow: var(--shadow-frame);
		border: 6px solid var(--gold);
	}
	.hero::before {
		content: "";
		position: absolute;
		inset: 12px;
		border: 2px solid rgba(201,164,65,.35);
		border-radius: calc(var(--radius) - 12px);
		pointer-events: none;
		background: repeating-linear-gradient(45deg, transparent, transparent 10px, rgba(201,164,65,.05) 10px, rgba(201,164,65,.05) 20px);
	}
	.hero-deco {
		position: absolute;
		font-size: 48px;
		opacity: .7;
		pointer-events: none;
		animation: float-dojo 5s ease-in-out infinite;
	}
	.hero-deco.d1 { top: 24px; left: 40px; animation-delay: 0s; }
	.hero-deco.d2 { top: 30px; right: 50px; animation-delay: 1.2s; }
	.hero-deco.d3 { bottom: 35px; left: 60px; animation-delay: 2.5s; }
	.hero-deco.d4 { bottom: 25px; right: 40px; animation-delay: .7s; }
	@keyframes float-dojo {
		0%, 100% { transform: translateY(0) rotate(0); }
		50% { transform: translateY(-10px) rotate(-3deg); }
	}
	.hero h1 {
		font-family: 'Yuji Syuku', serif;
		font-size: 44px;
		font-weight: 900;
		margin: 0 0 20px;
		line-height: 1.5;
		color: var(--cream);
		text-shadow: 3px 3px 0 rgba(217,58,46,.6);
		position: relative;
		z-index: 1;
	}
	.gradient-text {
		background: linear-gradient(135deg, var(--red), var(--gold));
		-webkit-background-clip: text;
		background-clip: text;
		color: transparent;
		font-size: 1.15em;
		position: relative;
		display: inline-block;
		padding: 0 8px;
	}
	.gradient-text::after {
		content: "極";
		position: absolute;
		top: -16px;
		right: -28px;
		font-size: 20px;
		color: var(--gold);
		background: var(--black);
		padding: 2px 8px;
		border-radius: 50%;
		border: 2px solid var(--gold);
	}
	.hero-sub {
		font-size: 17px;
		color: var(--cream);
		margin: 0 auto 32px;
		max-width: 580px;
		position: relative;
		z-index: 1;
		line-height: 2;
		letter-spacing: .5px;
	}
	.hero-stats {
		display: flex;
		justify-content: center;
		align-items: center;
		gap: 28px;
		margin: 32px 0;
		flex-wrap: wrap;
		position: relative;
		z-index: 1;
	}
	.stat-item {
		background: linear-gradient(135deg, var(--cream), #ebe0c8);
		border-radius: var(--radius-sm);
		padding: 16px 26px;
		box-shadow: 0 6px 16px rgba(0,0,0,.25);
		border: 3px solid var(--gold);
		min-width: 110px;
	}
	.stat-num {
		display: block;
		font-size: 32px;
		font-weight: 900;
		background: linear-gradient(135deg, var(--red), var(--gold));
		-webkit-background-clip: text;
		background-clip: text;
		color: transparent;
		font-family: 'Inter', sans-serif;
	}
	.stat-label {
		font-size: 13px;
		color: var(--black);
		font-weight: 700;
		letter-spacing: 1px;
	}
	.stat-divider {
		font-size: 24px;
		color: var(--gold);
	}
	.stat-divider::before {
		content: "◆";
	}
	.hero-btn {
		display: inline-flex;
		align-items: center;
		gap: 10px;
		background: linear-gradient(135deg, var(--red), #b82e25);
		color: #fff;
		font-weight: 900;
		font-size: 17px;
		padding: 18px 50px;
		border-radius: var(--radius-sm);
		text-decoration: none;
		box-shadow: 0 8px 22px rgba(217,58,46,.5), inset 0 -4px 0 rgba(0,0,0,.2);
		transition: .25s;
		position: relative;
		z-index: 1;
		letter-spacing: 1.5px;
		border: 2px solid rgba(255,255,255,.3);
	}
	.hero-btn::before {
		content: "入門";
		font-size: 19px;
		font-family: 'Yuji Syuku', serif;
	}
	.hero-btn:hover {
		transform: translateY(-4px) scale(1.04);
		box-shadow: 0 14px 32px rgba(217,58,46,.65), inset 0 -4px 0 rgba(0,0,0,.2);
	}

	/* Spotlight card */
	.spotlight-card {
		display: grid;
		grid-template-columns: 300px 1fr;
		gap: 32px;
		background: #fff;
		border-radius: var(--radius);
		padding: 24px;
		box-shadow: var(--shadow-frame);
		text-decoration: none;
		color: inherit;
		border: 6px solid var(--black);
		transition: .3s;
		position: relative;
		overflow: hidden;
	}
	.spotlight-card::before {
		content: "";
		position: absolute;
		inset: 10px;
		border: 2px solid var(--gold);
		border-radius: calc(var(--radius) - 10px);
		pointer-events: none;
		opacity: .6;
	}
	.spotlight-card:hover {
		transform: translateY(-6px);
		box-shadow: 0 12px 32px rgba(0,0,0,.35);
		border-color: var(--red);
	}
	.spotlight-img {
		border-radius: var(--radius-sm);
		aspect-ratio: 4/3;
		background: linear-gradient(135deg, var(--red-soft), var(--cream));
		position: relative;
		overflow: hidden;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 70px;
		border: 4px solid var(--black);
	}
	.badge-new {
		position: absolute;
		top: 14px;
		right: 14px;
		background: var(--red);
		color: #fff;
		font-weight: 900;
		font-size: 12px;
		padding: 6px 14px;
		border-radius: var(--radius-sm);
		box-shadow: 0 4px 10px rgba(217,58,46,.5);
